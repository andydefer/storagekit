{
    "name": "andydefer/storage-kit",
    "description": "Storage adapters : Memory, JSONL, and Cache",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andy Kani",
            "email": "andykanidimbu@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "andydefer/domain-structures": "^1.21",
        "andydefer/php-jsonl": "^0.7.0",
        "phpfastcache/phpfastcache": "^9.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.29",
        "symfony/var-dumper": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "AndyDefer\\StorageKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AndyDefer\\StorageKit\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}